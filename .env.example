# ─────────────────────────────────────────────────────────────
# Audible — environment variables
#
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local. The .gitignore blocks it, but don't
# override that. Secrets in version control are how bills happen.
# ─────────────────────────────────────────────────────────────

# ── Node / Next.js ──────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ── Database (Neon Postgres via Vercel Marketplace) ─────────────
# Set manually for local work, or pull later from Vercel after login.
DATABASE_URL=
# Runtime app pool size. Drizzle migrations also use DATABASE_URL.
DATABASE_POOL_MAX=10
# Legacy/emergency script only: scripts/push-schema.ts can use this unpooled URL.
# The supported migration path is bun run db:migrate with DATABASE_URL.
DATABASE_URL_UNPOOLED=

# ── Clerk (Auth) ────────────────────────────────────────────────
# Create a project at clerk.com, copy publishable + secret keys.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# ── Local-only coach auth bypass ────────────────────────────────
# Do not set these in preview or production.
DEV_BYPASS_AUTH=0
DEV_PROGRAM_ID=
DEV_ROLE=head_coach

# ── Player Sessions ─────────────────────────────────────────────
# Required outside local development. Generate with:
#   openssl rand -base64 48
PLAYER_SESSION_SECRET_CURRENT=
# Rotation only: keep old secrets temporarily while old tokens expire.
PLAYER_SESSION_PREVIOUS_SECRET=
PLAYER_SESSION_PREVIOUS_SECRETS=
# Deprecated legacy name: do not use for new environments. Production signing
# requires PLAYER_SESSION_SECRET_CURRENT.
# PLAYER_SESSION_SECRET=

# ── Rate Limiting (Upstash Redis) ───────────────────────────────
# Required for distributed player join-code throttling in preview/prod.
# Without these, local development falls back to in-memory rate limits.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Vercel AI Gateway ───────────────────────────────────────────
# Routes LLM calls with zero markup and provider fallback.
# Get your gateway key from the Vercel dashboard → AI Gateway.
AI_GATEWAY_API_KEY=

# ── Anthropic (primary LLM provider) ────────────────────────────
# Only used if you want to bypass AI Gateway. Prefer the gateway.
# Set a $10/month spend cap in the Anthropic console.
ANTHROPIC_API_KEY=

# ── OpenAI (secondary LLM for vision ensemble) ──────────────────
# Used alongside Anthropic in Phase 4.5 ensemble voting.
OPENAI_API_KEY=

# ── Google Gemini (video boundary/game analysis) ────────────────
GOOGLE_API_KEY=
GEMINI_API_KEY=

# ── Roboflow (optional player detection path) ───────────────────
ROBOFLOW_API_KEY=

# ── Vercel Blob (object storage) ────────────────────────────────
BLOB_READ_WRITE_TOKEN=

# ── Resend (transactional email) ────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=no-reply@audible.example

# ── Feature flags ───────────────────────────────────────────────
# Phase 4.5 vision tasks gated individually so we can enable per-program.
FLAG_CV_COVERAGE_SHELL=false
FLAG_CV_PRESSURE_TYPE=false
FLAG_CV_PRESSURE_SOURCE=false
FLAG_CV_COVERAGE_DISGUISE=false
FLAG_CV_ALIGNMENT_DEPTH=false

# ── Spend controls ──────────────────────────────────────────────
# Per-program daily spend cap in USD for vision API calls. Hard stop.
SPEND_CAP_VISION_USD_PER_PROGRAM_PER_DAY=5
# Max concurrent vision workers per program.
VISION_CONCURRENCY_PER_PROGRAM=5

# ── Observability ───────────────────────────────────────────────
SENTRY_DSN=
