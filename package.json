{
  "name": "audible",
  "version": "0.1.0",
  "private": true,
  "description": "Football intelligence platform for HS and D-II/D-III college football programs.",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "biome lint ./src ./tests",
    "format": "biome format --write ./src ./tests",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:evals": "vitest run --config vitest.evals.config.ts",
    "test:cv": "vitest run --config vitest.cv.config.ts",
    "test:db": "vitest run tests/integration/db",
    "test:e2e": "playwright test",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "ci": "bun run typecheck && bun run lint && bun run test && bun run test:evals"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.0",
    "@ai-sdk/openai": "^3.0.0",
    "@base-ui/react": "^1.3.0",
    "@clerk/nextjs": "^7.0.0",
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@ffprobe-installer/ffprobe": "^2.1.0",
    "@react-pdf/renderer": "^4.4.1",
    "@vercel/analytics": "^2.0.0",
    "@vercel/blob": "^2.0.0",
    "@vercel/functions": "^3.0.0",
    "@vercel/sandbox": "^1.9.3",
    "@vercel/speed-insights": "^2.0.0",
    "ai": "^6.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "csv-parse": "^6.0.0",
    "drizzle-orm": "^0.45.0",
    "fast-xml-parser": "^5.0.0",
    "lucide-react": "^1.8.0",
    "next": "^16.0.0",
    "postgres": "^3.4.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "resend": "^6.0.0",
    "shadcn": "^4.2.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@playwright/test": "^1.50.0",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vercel/config": "^0.1.0",
    "@vitejs/plugin-react": "^6.0.0",
    "drizzle-kit": "^0.31.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.8.0",
    "vitest": "^4.0.0"
  },
  "packageManager": "bun@1.3.11",
  "engines": {
    "node": ">=22.0.0"
  },
  "trustedDependencies": [
    "@clerk/shared",
    "@ffmpeg-installer/darwin-arm64",
    "@ffprobe-installer/darwin-arm64",
    "esbuild",
    "msw",
    "sharp"
  ]
}
